# Claude API
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Server Configuration
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Storage
STORAGE_PATH=./backend/storage

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_UPLOAD_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# LaTeX
LATEX_COMPILE_TIMEOUT=10
LATEX_DOCKER_IMAGE=resumebuilder-latex-compiler

# Claude API Settings
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7
